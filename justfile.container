# Go client library - container version
# This file is mounted as 'justfile' inside the container
# Also used directly in CI container jobs

set shell := ["bash", "-c"]

ROOT := `git rev-parse --show-toplevel`
VERSION := `cat VERSION 2>/dev/null || echo "dev"`
LDFLAGS := "-X github.com/benjaminabbitt/angzarr/client/go.Version=" + VERSION

default:
    @just --list

proto:
    cd {{ROOT}} && buf generate

build: proto
    go build -ldflags '{{LDFLAGS}}' ./...

test: proto
    go test -v ./...

coverage: proto
    go test -coverprofile=coverage.out ./... && go tool cover -func=coverage.out

mutation-test: proto
    go test -v -tags=mutation -run TestMutation -count=1 -timeout 30m ./...

# Format check (gofmt)
fmt:
    gofmt -l . | tee /tmp/gofmt.out && test ! -s /tmp/gofmt.out

# Auto-format code
fmt-fix:
    gofmt -w .
